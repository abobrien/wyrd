<!-- Weapon Grid -->
<div class="card">

    <!-- Body -->
    <div class="card-body">

        <!-- Grid -->
        <div id="weaponGrid" class="inventory-grid">

            <!-- Slot -->
            <div class="inventory-slot">
                <span class="slot-label">Main Hand</span>
            </div>

            <!-- Slot -->
            <div class="inventory-slot">
                <span class="slot-label">Off Hand</span>
            </div>

        </div>

    </div>

</div>

<script>
    const weaponGrid = document.getElementById("weaponGrid");

    weaponGrid.addEventListener("dragstart", event => {
        const item = event.target.closest(".inventory-item");

        if (!item) {
            return;
        }

        draggedItem = item;
        originalSlot = item.parentElement;

        item.classList.add("dragging");

        event.dataTransfer.effectAllowed = "move";
        event.dataTransfer.setData(
            "text/plain",
            item.dataset.itemId ?? ""
        );
    });

    weaponGrid.addEventListener("dragend", event => {
        const item = event.target.closest(".inventory-item");

        item?.classList.remove("dragging");

        weaponGrid
            .querySelectorAll(".inventory-slot.drag-over")
            .forEach(slot => slot.classList.remove("drag-over"));

        draggedItem = null;
        originalSlot = null;
    });

    weaponGrid.addEventListener("dragover", event => {
        const slot = event.target.closest(".inventory-slot");

        if (!slot || !draggedItem) {
            return;
        }

        event.preventDefault();
        event.dataTransfer.dropEffect = "move";

        weaponGrid
            .querySelectorAll(".inventory-slot.drag-over")
            .forEach(currentSlot => {
                if (currentSlot !== slot) {
                    currentSlot.classList.remove("drag-over");
                }
            });

        slot.classList.add("drag-over");
    });

    weaponGrid.addEventListener("dragleave", event => {
        const slot = event.target.closest(".inventory-slot");

        if (!slot) {
            return;
        }

        const nextElement = event.relatedTarget;

        if (!nextElement || !slot.contains(nextElement)) {
            slot.classList.remove("drag-over");
        }
    });

    weaponGrid.addEventListener("drop", event => {
        const targetSlot = event.target.closest(".inventory-slot");

        if (!targetSlot || !draggedItem || !originalSlot) {
            return;
        }

        event.preventDefault();
        targetSlot.classList.remove("drag-over");

        if (targetSlot === originalSlot) {
            return;
        }

        const targetItem = targetSlot.querySelector(".inventory-item");

        /*
         * If the destination is occupied, move that item
         * into the dragged item's original slot.
         */
        if (targetItem) {
            originalSlot.appendChild(targetItem);
        }

        targetSlot.appendChild(draggedItem);

        saveWeapon();
    });

    function saveWeapon() {
        const inventory = [...weaponGrid.children].map(slot => {
            const item = slot.querySelector(".inventory-item");
            return item?.dataset.itemId ?? null;
        });

        console.log("Inventory state:", inventory);

        // Optional:
        // localStorage.setItem("inventory", JSON.stringify(inventory));
    }
</script>