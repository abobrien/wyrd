<script>
    const currentSection = "<%= userSession.currentSection %>";

    document.addEventListener("DOMContentLoaded", () => {
        console.log(`Session section: ${currentSection}`);

        document.querySelectorAll(".nav-item").forEach(item => {
            const section = item.querySelector("span")?.textContent.trim();

            if (section === currentSection) {
                console.log(`Matched section: ${section}`);

                item.querySelector(".nav-link.dropdown-toggle")?.classList.add("show");
                item.querySelector(".dropdown-menu.expanded")?.classList.add("show");
            }
        });
    });
</script>